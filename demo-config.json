{
  "baseUrl": "https://app.uniswap.org",
  "viewport": { "width": 1920, "height": 1080 },
  "walletAction": "none",
  "flows": [
    {
      "name": "uniswap-homepage",
      "path": "/",
      "description": "Uniswap homepage load and scroll",
      "waitForSelector": "body",
      "duration": 8,
      "actions": [
        { "type": "wait", "duration": 3 },
        { "type": "scroll", "direction": "down", "amount": 500, "delay": 2 },
        { "type": "scroll", "direction": "down", "amount": 500, "delay": 2 }
      ]
    }
  ]
}
