# DAPPSNAP — Environment Variables
# Copy this file to .env and fill in your TEST wallet values.
# NEVER commit .env to git. NEVER use a wallet with real funds.

# --- walletAction: 'inject' (headless, no extension) ---
# Private key for headless wallet injection (hex, with 0x prefix)
# Export from MetaMask: Account Details > Show Private Key
# Test wallet 0xc45A...078F only. Zero real funds.
WALLET_PRIVATE_KEY=0xYOUR_TEST_WALLET_PRIVATE_KEY_HERE

# Chain ID (1 = Ethereum mainnet, 11155111 = Sepolia testnet)
CHAIN_ID=1

# RPC URL (public endpoint, no API key needed)
RPC_URL=https://eth.llamarpc.com

# --- Path D: remote CDP screencast (Mac Mini → Mac Air Chrome) ---
# Mac Air Tailscale IP (Chrome running with --remote-debugging-port=9222)
CDP_HOST=100.68.19.10
CDP_PORT=9222

# --- walletAction: 'connect' (headed, MetaMask extension via Synpress) ---
# Only needed if using walletAction: 'connect' (requires display)
WALLET_SEED_PHRASE=your_test_mnemonic_here_never_real_funds
WALLET_PASSWORD=your_password_here
